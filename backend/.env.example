# Database connection string. Replace with PostgreSQL for production.
DATABASE_URL=sqlite:///./dundaa.db
# Secret used to sign JWT access tokens.
JWT_SECRET_KEY=REPLACE_ME
# JWT signing algorithm.
JWT_ALGORITHM=HS256
# Access token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Payment provider placeholders.
MPESA_CONSUMER_KEY=REPLACE_ME
MPESA_CONSUMER_SECRET=REPLACE_ME
BANK_PAYOUT_KEY=REPLACE_ME
CARD_PROCESSOR_KEY=REPLACE_ME
# Base URL for your backend.
APP_BASE_URL=http://localhost:8000
